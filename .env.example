# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_MEDIA=zardonic-media
R2_PUBLIC_HOST=https://pub-xxxx.r2.dev

# App
NEXT_PUBLIC_SITE_URL=https://zardonic-website.vercel.app

# Contact form recipient (optional – defaults to contact@zardonic.com)
CONTACT_EMAIL=your@email.com

# AES-256-GCM master key for encrypted API secrets in Supabase (64 hex chars / 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_ENCRYPTION_KEY=

# Integration API keys — prefer Admin → API Keys (encrypted in Supabase).
# Env vars below are optional fallbacks during migration:
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# DISCOGS_TOKEN=
# BANDSINTOWN_API_KEY=
# RESEND_API_KEY=re_...

# Dev Mode (set to true to use mock/demo data instead of Supabase)
NEXT_PUBLIC_DEV_MODE=true
NEXT_PUBLIC_HIDE_DEMO_FALLBACK=false
NEXT_PUBLIC_SHOW_DEMO_BADGE=false
